{
    "name": "@saas/shared",
    "version": "1.0.0",
    "description": "Shared types and utilities for SaaS Collaborative Platform",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "typescript": "^5.2.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/node": "^20.8.0"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./types": {
            "types": "./dist/types/index.d.ts",
            "default": "./dist/types/index.js"
        }
    }
}