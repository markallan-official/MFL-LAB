{
    "name": "@saas/backend",
    "version": "1.0.0",
    "description": "Backend API server for SaaS Collaborative Platform",
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "test": "vitest",
        "test:unit": "vitest run --reporter=verbose",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src --ext .ts,.tsx",
        "format": "prettier --write \"src/**/*.ts\"",
        "type-check": "tsc --noEmit",
        "db:migrate": "prisma migrate dev",
        "db:deploy": "prisma migrate deploy",
        "db:seed": "node --loader tsx prisma/seed.ts",
        "db:reset": "prisma migrate reset --force",
        "prisma:generate": "prisma generate"
    },
    "dependencies": {
        "@prisma/client": "^5.3.0",
        "@sendgrid/mail": "^7.7.0",
        "axios": "^1.4.0",
        "bcryptjs": "^2.4.3",
        "bull": "^4.11.1",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^6.7.0",
        "helmet": "^7.0.0",
        "ioredis": "^5.3.2",
        "jsonwebtoken": "^9.0.2",
        "kafkajs": "^2.2.4",
        "luxon": "^3.3.0",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^8.0.1",
        "passport": "^0.6.0",
        "passport-oauth2": "^1.7.0",
        "redis": "^4.6.10",
        "sharp": "^0.32.0",
        "speakeasy": "^2.0.0",
        "typescript": "^5.2.0",
        "uuid": "^9.0.0",
        "winston": "^3.11.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/express": "^4.17.20",
        "@types/jest": "^29.5.5",
        "@types/node": "^20.8.0",
        "@types/nodemailer": "^7.0.11",
        "@types/supertest": "^2.0.12",
        "@typescript-eslint/eslint-plugin": "^6.7.2",
        "@typescript-eslint/parser": "^6.7.2",
        "axios-mock-adapter": "^1.21.2",
        "cross-env": "^7.0.3",
        "eslint": "^8.50.0",
        "jest-mock-extended": "^3.0.5",
        "prettier": "^3.0.0",
        "prisma": "^5.3.0",
        "supertest": "^6.3.3",
        "tsx": "^3.14.0",
        "vitest": "^0.34.4"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
