# SaaS Platform Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# Application Configuration
# ============================================

NODE_ENV=development
APP_NAME="SaaS Collaborative Platform"
APP_VERSION=1.0.0
APP_PORT=3000
API_PORT=3000
FRONTEND_PORT=5173

