# ============================================
# Frontend Configuration
# ============================================

VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
VITE_APP_NAME=SaaS Platform
VITE_SUPABASE_URL=https://yvaidjzhhejrfgpovzmm.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inl2YWlkanpoaGVqcmZncG92em1tIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIwNDMxOTcsImV4cCI6MjA4NzYxOTE5N30.uyREMgiTD5o5it4SB5xFoBalKItB_5z-ehOFafQl_vo

# ============================================
# Database Configuration (Legacy - Use Supabase Above)
# ============================================

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas_dev
DATABASE_URL_READ=postgresql://postgres:postgres@localhost:5432/saas_dev
DATABASE_POOL_SIZE=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_IDLE=600

# ============================================
# Redis Configuration
# ============================================

REDIS_URL=redis://localhost:6379
REDIS_CLUSTER_NODES=localhost:6379
REDIS_PASSWORD=
REDIS_TTL=3600

# ============================================
# Authentication Configuration
# ============================================

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=900
REFRESH_TOKEN_EXPIRY=604800
JWT_SIGNING_ALGORITHM=RS256
JWT_PUBLIC_KEY_PATH=./keys/public.key
JWT_PRIVATE_KEY_PATH=./keys/private.key

# OAuth Configuration
OAUTH_GITHUB_ID=
OAUTH_GITHUB_SECRET=
OAUTH_GOOGLE_ID=
OAUTH_GOOGLE_SECRET=
OAUTH_AZURE_ID=
OAUTH_AZURE_SECRET=
OAUTH_OKTA_DOMAIN=

# Session Configuration
SESSION_SECRET=your-session-secret-key-change-in-production
SESSION_TIMEOUT=86400
SESSION_REFRESH_INTERVAL=3600

# ============================================
# Email Configuration
# ============================================

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_FROM_NAME="SaaS Platform"

# Fallback SMTP Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ============================================
# File Storage Configuration
# ============================================

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=saas-platform-dev
S3_BUCKET_REGION=us-east-1

# File Upload
MAX_FILE_SIZE=104857600  # 100MB
ALLOWED_FILE_TYPES=jpg,png,gif,pdf,doc,docx,xls,xlsx,zip,rar,mp4,avi
FILE_UPLOAD_DIR=./uploads
FILE_STORAGE_STRATEGY=local  # 'local' or 's3'

# ============================================
# Kafka Configuration (Optional)
# ============================================

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=saas-platform-dev
KAFKA_CONSUMER_GROUP=saas-platform-consumers
KAFKA_TOPICS_WORKSPACE_EVENTS=workspace-events
KAFKA_TOPICS_USER_ACTIVITIES=user-activities
KAFKA_TOPICS_BUILD_PIPELINE=build-pipeline
KAFKA_TOPICS_NOTIFICATIONS=notifications

# ============================================
# Logging Configuration
# ============================================

LOG_LEVEL=debug
LOG_FORMAT=json  # 'json' or 'text'
LOG_DIR=./logs
LOG_MAX_SIZE=10485760  # 10MB
LOG_RETENTION_DAYS=30

# ============================================
# Monitoring & Observability
# ============================================

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=1.0.0

# Prometheus Metrics
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=false

# ============================================
# Security Configuration
# ============================================

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# Rate Limiting
RATE_LIMIT_WINDOW=900000  # 15 minutes in ms
RATE_LIMIT_MAX_REQUESTS=100

# HTTPS/TLS
HTTPS_ENABLED=false
SSL_CERT_PATH=
SSL_KEY_PATH=

# ============================================
# Feature Flags
# ============================================

FEATURE_MFA_REQUIRED=true
FEATURE_OAUTH_ENABLED=true
FEATURE_KAFKA_ENABLED=false
FEATURE_GRAPHQL_ENABLED=false
FEATURE_API_RATE_LIMITING=true
FEATURE_IP_WHITELIST=false

# ============================================
# Admin Configuration
# ============================================

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123!  # Change in production!
ADMIN_AUTO_APPROVAL=false

# ============================================
# Compliance & Data Retention
# ============================================

# GDPR/CCPA
DATA_RESIDENCY_REGION=US
DATA_RETENTION_DAYS=365
ENABLE_RIGHT_TO_DELETE=true
ENABLE_DATA_EXPORT=true

# Audit
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years
AUDIT_SENSITIVE_FIELDS=password,token,secret,key

# ============================================
# Development Configuration
# ============================================

# Debug Mode
DEBUG=saas:*
VERBOSE_LOGGING=false

# Mock Services
MOCK_EMAIL_DELIVERY=true  # Don't send emails in dev
MOCK_FILE_UPLOAD=false

# Database
DB_SEED_DATA=true
DB_AUTO_MIGRATE=true
DB_RESET_ON_START=false  # ⚠️ Dangerous! Only for development

# API
API_DOCS_ENABLED=true
API_PLAYGROUND_ENABLED=true

# WebSocket
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_BACKOFF=30000

# ============================================
# Deployment Configuration
# ============================================

# Docker
DOCKER_REGISTRY=
DOCKER_IMAGE_PREFIX=saas-platform
DOCKER_TAG=latest

# Kubernetes
K8S_NAMESPACE=default
K8S_REPLICAS=1
K8S_CPU_REQUEST=100m
K8S_CPU_LIMIT=500m
K8S_MEMORY_REQUEST=128Mi
K8S_MEMORY_LIMIT=512Mi

# ============================================
# IMPORTANT SECURITY NOTES
# ============================================

# 1. Never commit this file to git with real values
# 2. Use .env.local for local development only
# 3. Use proper secret management (AWS Secrets Manager, HashiCorp Vault) in production
# 4. Rotate secrets regularly
# 5. Use different secrets per environment (dev/staging/production)
# 6. Keep sensitive values out of logs and error messages
